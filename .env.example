# ============================================================
# BOAMP × Cohesity — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Flask
SECRET_KEY=change-me-in-production-use-a-long-random-string
FLASK_ENV=production
FLASK_DEBUG=False

# Serveur
# Port 5000 est souvent occupé par AirPlay Receiver sur macOS — utiliser 5001
PORT=5001
# URL publique de l'application — utilisée pour les liens dans les emails d'alerte
# (le scheduler tourne hors contexte HTTP et ne peut pas déduire le domaine seul)
APP_BASE_URL=https://vigie-ao.domain.com

# Sécurité utilisateurs
ALLOWED_EMAIL_DOMAIN=domain.com
AUTO_ACTIVATE=True
# Email du premier compte admin créé au démarrage si la base est vide
ADMIN_EMAIL=admin@domain.com
# Mot de passe du compte admin initial (modifiez-le après la première connexion !)
ADMIN_DEFAULT_PASSWORD=ChangeMe!2024

# Email SMTP
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=alerts@domain.com
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=Vigie AO <alerts@domain.com>

# BOAMP
BOAMP_REFRESH_INTERVAL_HOURS=4
BOAMP_CACHE_TTL_HOURS=4

# TED — Tenders Electronic Daily (marchés européens)
# Clé API à obtenir sur https://developer.ted.europa.eu
TED_API_KEY=your-ted-api-key
TED_ENABLED=False
